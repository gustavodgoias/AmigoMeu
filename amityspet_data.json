        "hoverBackground": "#63B22F",
        "hoverTextColor": "#FFFFFF",
        "padding": "13px 31px",
        "fontWeight": 700,
        "letterSpacing": "0.05em",
        "textTransform": "uppercase",
        "fontSize": "14px"
      },
      "buttonBlue": {
        "background": "#6EC1E4",
        "textColor": "#FFFFFF",
        "borderRadius": "0px",
        "hoverBackground": "#4ea8cf",
        "shadow": "none",
        "padding": "14px 32px",
        "fontWeight": 700
      },

      "card": {
        "background": "#FFFFFF",
        "borderRadius": "0px",
        "border": "1px solid #e8e8e8",
        "shadow": "0 2px 8px rgba(0,0,0,0.06)",
        "hoverShadow": "0 8px 40px rgba(0,0,0,0.12)",
        "padding": "32px"
      },

      "section": {
        "paddingBlock": "clamp(5rem, 10vw, 10rem)",
        "backgroundAlternate": "#f7faf5"
      },

      "nav": {
        "background": "transparent (on top) / white with blur (on scroll)",
        "linkColor": "#1a1a1a",
        "linkHoverColor": "#63B22F",
        "linkFontWeight": 600,
        "linkFontSize": "14px",
        "linkLetterSpacing": "0.05em"
      },

      "footer": {
        "background": "#111118",
        "textColor": "rgba(255,255,255,0.7)",
        "borderRadius": "60px 60px 0 0",
        "headingColor": "rgba(255,255,255,0.4)"
      },

      "kicker": {
        "color": "#63B22F",
        "background": "rgba(99,178,47,0.08)",
        "border": "1px solid rgba(99,178,47,0.2)",
        "borderRadius": "9999px",
        "fontSize": "11px",
        "fontWeight": 700,
        "letterSpacing": "0.25em",
        "textTransform": "uppercase",
        "padding": "6px 16px"
      },

      "badge": {
        "background": "rgba(99,178,47,0.08)",
        "textColor": "#4a8a22",
        "borderRadius": "9999px",
        "fontSize": "12px",
        "fontWeight": 700,
        "letterSpacing": "0.06em",
        "padding": "4px 12px"
      }
    },

    "layout": {
      "heroHeadingTextTransform": "uppercase",
      "sectionHeadingAlignment": "center",
      "productCarouselStyle": "horizontal scroll / slider",
      "gridColumns": {
        "features": 4,
        "products": 3,
        "contacts": 4,
        "footer": 3
      }
    },

    "animations": {
      "duration": "400ms",
      "easing": "cubic-bezier(0.16, 1, 0.3, 1)",
      "hoverTranslateY": "-4px",
      "scrollReveal": "fade-in-up with 0.3s delay stagger"
    },

    "personality": {
      "tone": "playful yet premium",
      "energy": "high",
      "targetAudience": "pet owners, distributors",
      "keywords": ["natural", "sustainable", "cassava", "eco", "premium", "animal welfare"],
      "visualStyle": "clean white backgrounds, bold green accents, sharp corners, uppercase headings, generous whitespace"
    }
  },

