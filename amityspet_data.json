      "textPrimary": "#63B22F",
      "textDark": "#1a1a1a",
      "textMuted": "#666666",
      "textLight": "#999999",

      "border": "#e8e8e8",
      "borderLight": "#f2f2f2",

      "white": "#FFFFFF",
      "black": "#111118",

      "overlay": "rgba(0,0,0,0.5)",
      "glass": "rgba(255,255,255,0.85)"
