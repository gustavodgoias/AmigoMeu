        "xs": "12px",
        "sm": "14px",
        "base": "16px",
        "md": "18px",
        "lg": "24px",
        "xl": "32px",
        "2xl": "48px",
        "3xl": "69px",
        "hero": "clamp(2.5rem, 6vw, 5rem)"
      },

      "fontWeights": {
        "light": 300,
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700,
        "extrabold": 800
      },

      "lineHeights": {
        "tight": 1.1,
        "snug": 1.25,
        "normal": 1.6,
        "relaxed": 1.8
      },

      "letterSpacing": {
        "tight": "-0.02em",
        "normal": "0",
        "wide": "0.05em",
        "wider": "0.12em",
        "widest": "0.25em"
      }
    },

    "spacing": {
      "baseUnit": 4,
      "scale": {
        "1": "4px",
        "2": "8px",
        "3": "12px",
        "4": "16px",
        "5": "20px",
        "6": "24px",
        "8": "32px",
        "10": "40px",
        "12": "48px",
        "16": "64px",
        "20": "80px",
        "24": "96px",
        "32": "128px"
      },
      "sectionPadding": "clamp(4rem, 8vw, 8rem)",
      "containerMax": "1200px",
      "containerPadding": "clamp(1.2rem, 4vw, 3rem)"
    },

    "borderRadius": {
      "none": "0px",
      "sm": "3px",
      "md": "6px",
      "lg": "12px",
      "xl": "20px",
      "2xl": "32px",
      "pill": "9999px",
