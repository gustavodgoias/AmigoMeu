    "colorScheme": "light",

    "colors": {
      "primary": "#6EC1E4",
      "primaryDark": "#4ea8cf",
      "primaryLight": "#a0d8f0",

      "accent": "#63B22F",
      "accentDark": "#4a8a22",
      "accentLight": "#8ed456",

      "secondary": "#61CE70",
      "secondaryDark": "#3faa50",
      "secondaryLight": "#90e09c",

      "background": "#FFFFFF",
      "backgroundAlt": "#f7faf5",
